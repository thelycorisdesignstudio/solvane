{
  "name": "solvane-document-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "cd client && npm run dev",
    "server": "cd server && npm run dev",
    "build": "cd client && npm run build",
    "check": "node --check server/server.js && cd client && npm run build",
    "smoke:free": "node scripts/smoke-free-workspace.mjs",
    "desktop:build": "npm run build && electron-builder --mac dmg --linux AppImage deb --publish never",
    "desktop:build:linux": "npm run build && electron-builder --linux AppImage deb --publish never",
    "desktop:build:mac": "npm run build && electron-builder --mac dmg --publish never"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "main": "desktop/main.cjs",
  "build": {
    "appId": "com.thelycoris.solvane",
    "productName": "Solvane",
    "files": [
      "desktop/**/*",
      "client/dist/**/*",
      "package.json",
      "scripts/after-sign-mac.cjs"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "afterSign": "scripts/after-sign-mac.cjs",
    "linux": {
      "category": "Office",
      "target": [
        "AppImage",
        "deb"
      ],
      "maintainer": "The Lycoris Labs <hello@thelycoris.com>"
    }
  },
  "description": "Solvane — open-source Document OS",
  "author": "The Lycoris Labs and The Lycoris Foundation"
}
